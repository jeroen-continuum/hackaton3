# Database — defaults to local SQLite; docker-compose overrides with Postgres
DB_URL=sqlite:///./data/app.db

# External data-source API keys (free tiers)
APOLLO_API_KEY=
HUNTER_API_KEY=
VDAB_API_KEY=
WAPPALYZER_API_KEY=

# LLM for outreach generation
ANTHROPIC_API_KEY=
